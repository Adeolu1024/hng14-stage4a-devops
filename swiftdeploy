def cmd_promote_4b(args):
    # Run pre-promote OPA check when promoting to canary
    if args.mode.lower() == "canary":
        try:
            pre_promote_check()
        except SystemExit:
            print("[FAIL] Pre-promote check cancelled promotion.")
            sys.exit(1)

    # Run original promote logic
    cmd_promote(args)


# ---------------------------------------------------------------------------
# Subcommand: status (live dashboard)
# ---------------------------------------------------------------------------
def cmd_status(args):
    print("[INFO] SwiftDeploy Status Dashboard (press Ctrl+C to stop)\n")

    prev_metrics = None
    prev_time = time.time()

    try:
        while True:
            port = load_manifest().get("nginx", {}).get("port", 8080)
            metrics = scrape_metrics(port)

            now = time.time()
            delta = now - prev_time

            # Calculate req/s
            reqs_now = sum(metrics.get("http_requests_total", {}).values())
            if prev_metrics:
                reqs_prev = sum(prev_metrics.get("http_requests_total", {}).values())
                reqs_per_sec = (reqs_now - reqs_prev) / max(delta, 1)
            else:
                reqs_per_sec = 0

            error_rate, p99_ms = calculate_p99_from_metrics(metrics)

            mode_label = "canary" if metrics["app_mode"] == 1 else "stable"
            chaos_labels = {0: "none", 1: "slow", 2: "error"}
            chaos_label = chaos_labels.get(metrics["chaos_active"], "none")

            # Query OPA for current policy compliance
            host_stats = get_host_stats()
            infra_decision = query_opa("infrastructure", {**host_stats, "check_type": "status"})

            canary_input = {
                "error_rate": round(error_rate, 6),
                "p99_latency_ms": round(p99_ms, 2),
                "window_seconds": 30,
                "check_type": "status"
            }
            canary_decision = query_opa("canary", canary_input)

            # Save to history
            record = {
                "timestamp": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
                "check_type": "status",
                "reqs_per_sec": round(reqs_per_sec, 2),
                "p99_latency_ms": round(p99_ms, 2),
                "error_rate": round(error_rate, 6),
                "mode": mode_label,
                "chaos": chaos_label,
                "infra_policy": infra_decision.get("allowed", False),
                "canary_policy": canary_decision.get("allowed", False)
            }
            append_history(record)

            # Clear terminal and display
            # Use simple approach — carriage return
            display = (
                f"  ╔═══════════════════════════════════════╗\n"
                f"  ║     SwiftDeploy Status Dashboard      ║\n"
                f"  ╠═══════════════════════════════════════╣\n"
                f"  ║ Mode: {mode_label:<28s} ║\n"
                f"  ║ Chaos: {chaos_label:<27s} ║\n"
                f"  ║ Req/s: {reqs_per_sec:<8.2f}               ║\n"
                f"  ║ P99 Latency: {p99_ms:<8.0f}ms             ║\n"
                f"  ║ Error Rate: {error_rate*100:<5.2f}%               ║\n"
                f"  ║ Uptime: {metrics['app_uptime_seconds']:<8.0f}s              ║\n"
                f"  ╠═══════════════════════════════════════╣\n"
                f"  ║ Policy Compliance                    ║\n"
                f"  ║   Infrastructure: {'PASS' if infra_decision.get('allowed', False) else 'FAIL':<5s}           ║\n"
                f"  ║   Canary Safety:  {'PASS' if canary_decision.get('allowed', False) else 'FAIL':<5s}           ║\n"
                f"  ╚═══════════════════════════════════════╝\n"
            )

            sys.stdout.write("\033[2J\033[H")  # Clear screen
            sys.stdout.write(display)
            sys.stdout.flush()

            prev_metrics = metrics
            prev_time = now
            time.sleep(2)

    except KeyboardInterrupt:
        print("\n[INFO] Status dashboard stopped.")
        sys.exit(0)


# ---------------------------------------------------------------------------
# Subcommand: audit (generate report)
# ---------------------------------------------------------------------------
def cmd_audit(args):
    print("[INFO] Generating audit report...")

    if not os.path.exists(HISTORY_FILE):
        print("[FAIL] No history data found. Run 'swiftdeploy status' first.")
        sys.exit(1)

    # Read all history records
    records = []
    with open(HISTORY_FILE, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:
                try:
                    records.append(json.loads(line))
                except json.JSONDecodeError:
                    pass

    if not records:
        print("[FAIL] No valid history records found.")
        sys.exit(1)

    lines = []
    lines.append("# Audit Report — SwiftDeploy Stage 4B")
    lines.append("")
    lines.append(f"**Generated:** {time.strftime('%Y-%m-%d %H:%M:%S UTC', time.gmtime())}")
    lines.append(f"**Records Analyzed:** {len(records)}")
    lines.append("")

    # Timeline
    lines.append("## Timeline")
    lines.append("")
    lines.append("| Timestamp | Event | Mode | Chaos | Details |")
    lines.append("|-----------|-------|------|-------|---------|")

    timeline_events = []
    chaos_events = []
    violations = []

    for r in records:
        ts = r.get("timestamp", "unknown")
        ct = r.get("check_type", "unknown")

        # Track mode changes
        if ct in ("status",):
            mode = r.get("mode", "unknown")
            chaos = r.get("chaos", "unknown")
            timeline_events.append((ts, "status_update", mode, chaos))

        # Track chaos via /metrics
        if ct in ("status",):
            chaos_val = r.get("chaos", "none")
            if chaos_val != "none":
                chaos_events.append((ts, f"chaos_{chaos_val}", r.get("mode", "unknown")))

        # Track violations
        allowed = r.get("allowed", True)
        if not allowed:
            violations.append(r)

    # Timeline table
    for evt in timeline_events[-20:]:  # Last 20
        lines.append(f"| {evt[0]} | {evt[1]} | {evt[2]} | {evt[3]} | |")

    if chaos_events:
        lines.append("")
        lines.append("### Chaos Injection Events")
        lines.append("")
        lines.append("| Timestamp | Mode | Description |")
        lines.append("|-----------|------|-------------|")
        for ce in chaos_events[-10:]:
            desc = "Slow mode activated" if "slow" in ce[1] else "Error mode activated"
            lines.append(f"| {ce[0]} | {ce[2]} | {desc} |")

    lines.append("")
    lines.append("## Policy Violations")
    lines.append("")

    if violations:
        lines.append("| Timestamp | Check Type | Domain | Reasons |")
        lines.append("|-----------|------------|--------|---------|")
        for v in violations:
            ts = v.get("timestamp", "unknown")
            ct = v.get("check_type", "unknown")
            dom = v.get("domain", "unknown")
            reasons = "; ".join(v.get("reasons", []))
            lines.append(f"| {ts} | {ct} | {dom} | {reasons} |")
    else:
        lines.append("No policy violations recorded.")

    lines.append("")
    lines.append("---")
    lines.append("")
    lines.append("_Report generated by swiftdeploy audit_")

    # Write report
    report = "\n".join(lines)
    with open("audit_report.md", "w", encoding="utf-8") as f:
        f.write(report)

    print(f"[OK]   audit_report.md generated ({len(records)} records analyzed).")
    print(f"[OK]   Report contains {len(violations)} policy violation(s).")


# ---------------------------------------------------------------------------
# Main entrypoint
# ---------------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(
        prog="swiftdeploy",
        description="SwiftDeploy - Build the Tool That Builds the Stack"
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    subparsers.add_parser("init", help="Parse manifest and generate config files")
    subparsers.add_parser("validate", help="Run pre-flight checks")
    subparsers.add_parser("deploy", help="Init with OPA pre-check, bring up stack")

    promote_parser = subparsers.add_parser("promote", help="Switch deployment mode (canary/stable) with OPA safety check")
    promote_parser.add_argument("mode", choices=["canary", "stable"], help="Target mode")

    subparsers.add_parser("status", help="Live terminal dashboard with metrics and policy compliance")
    subparsers.add_parser("audit", help="Generate audit_report.md from history.jsonl")

    teardown_parser = subparsers.add_parser("teardown", help="Remove all containers, networks, and volumes")
    teardown_parser.add_argument("--clean", action="store_true", help="Also delete generated configs")

    args = parser.parse_args()

    if args.command == "init":
        cmd_init(args)
    elif args.command == "validate":
        cmd_validate(args)
    elif args.command == "deploy":
        cmd_deploy_4b(args)
    elif args.command == "promote":
        cmd_promote_4b(args)
    elif args.command == "status":
        cmd_status(args)
    elif args.command == "audit":
        cmd_audit(args)
    elif args.command == "teardown":
        cmd_teardown(args)


if __name__ == "__main__":
    main()
