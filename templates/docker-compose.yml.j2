# Auto-generated by swiftdeploy — DO NOT EDIT

services:
  {{ service_name }}:
    image: {{ service_image }}
    container_name: {{ service_name }}
    environment:
      - MODE={{ mode }}
      - APP_VERSION={{ app_version }}
      - APP_PORT={{ service_port }}
    networks:
      - {{ network_name }}
    volumes:
      - {{ log_volume }}:/var/log/swiftdeploy
    restart: {{ restart_policy }}
    cap_drop:
      - ALL
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{{ service_port }}/healthz')"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s
    # Service port is NOT exposed directly

  nginx:
    image: {{ nginx_image }}
    container_name: nginx-proxy
    ports:
      - "{{ nginx_host_port }}:{{ nginx_port }}"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - {{ log_volume }}:/var/log/nginx
    networks:
      - {{ network_name }}
    restart: {{ restart_policy }}
    depends_on:
      {{ service_name }}:
        condition: service_healthy

networks:
  {{ network_name }}:
    driver: {{ network_driver }}

volumes:
  {{ log_volume }}:
